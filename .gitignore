# ------------------------------------------------------------------------------
# Open Claw Sandbox Runtime Data
# ------------------------------------------------------------------------------
open-claw-sandbox/data/
open-claw-sandbox/models/
open-claw-sandbox/logs/

# ------------------------------------------------------------------------------
# Universal Ignore Patterns
# ------------------------------------------------------------------------------

# macOS metadata
.DS_Store
**/.DS_Store

# Python bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Python packaging
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Ruff / Mypy caches
.ruff_cache/
.mypy_cache/

# ------------------------------------------------------------------------------
# Open WebUI Runtime Data (databases change on every session)
# ------------------------------------------------------------------------------
infra/open-webui/vector_db/
infra/open-webui/webui.db
infra/open-webui/webui.db-shm
infra/open-webui/webui.db-wal

# ------------------------------------------------------------------------------
# Local Workspace Runtime Files
# ------------------------------------------------------------------------------
logs/
*.log
.webui_secret_key
gemini_quota.json

# ------------------------------------------------------------------------------
# Scratch / One-off Test Files
# ------------------------------------------------------------------------------
test_exec.py

