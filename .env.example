# ================================
# Local Workspace — Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ================================
# Open Claw Workspace
# ================================
WORKSPACE_DIR=/absolute/path/to/local-workspace/open-claw-workspace
HF_HOME=/absolute/path/to/local-workspace/open-claw-workspace/models

# ================================
# Ollama
# ================================
OLLAMA_HOST=http://localhost:11434

# ================================
# LiteLLM Proxy
# ================================
LITELLM_HOST=http://localhost:4000

# ================================
# Open WebUI
# ================================
WEBUI_HOST=http://localhost:3000

# ================================
# External API Keys (optional)
# ================================
GEMINI_API_KEY=          # Google Gemini API Key (if using cloud fallback)
