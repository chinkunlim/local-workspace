# 使用 Open Claw 預設沙盒為基底
FROM openclaw-sandbox-common:bookworm-slim

# 1. 提升權限為 root 以允許安裝系統軟體
USER root

# 2. 安裝系統級的音訊處理工具 ffmpeg
RUN apt-get update && apt-get install -y ffmpeg python3-pip

# 3. 安裝 Python 核心處理套件
RUN pip install --no-cache-dir --break-system-packages openai-whisper pydub psutil pypdf requests faster-whisper ctranslate2
